# ============================================
# API Keys (Required)
# ============================================

# OpenAI API Key (for LLM features, storybook generation)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key (for image generation and Veo video)
GOOGLE_API_KEY=your_google_api_key_here

# FAL AI API Key (alternative image generation service)
FAL_API_KEY=your_fal_api_key_here

# ElevenLabs API Key (for audio/voice generation)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# HyperBrowser API Key (for web scraping)
HYPERBROWSER_API_KEY=your_hyperbrowser_api_key_here

# Veo3 API Key (if different from GEMINI_API_KEY)
VEO3_API_KEY=your_veo3_api_key_here

# ============================================
# Supabase Configuration (for cloud storage)
# ============================================

# Supabase URL
SUPABASE_URL=your_supabase_url_here

# Supabase Secret Key (NEW - Recommended format: sb_secret_...)
# Get this from: Supabase Dashboard > Project Settings > API > Create new API Keys
SUPABASE_SECRET_KEY=sb_secret_your_secret_key_here

# Legacy Supabase Service Key (for backward compatibility - optional)
# SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# ============================================
# Optional Configuration
# ============================================

# Default image generation service: "google" or "fal"
DEFAULT_IMAGE_SERVICE=google

# Default storage service: "supabase" or "local"
DEFAULT_STORAGE_SERVICE=supabase

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8005

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:8005
