# ============================================
# Frontend-Specific Configuration
# ============================================
# Note: API keys should be set in the root .env file
# This file contains optional frontend-specific settings

# ============================================
# Model Configuration
# ============================================

# OpenAI model for summary generation
OPENAI_SUMMARY_MODEL=gpt-5-nano

# Gemini model for content generation
GEMINI_MODEL=gemini-2.0-flash-exp

# Veo model for video generation
VEO_MODEL=veo-001

# ============================================
# Development Settings
# ============================================

# Backend API URL (for development)
# NEXT_PUBLIC_API_URL=http://localhost:8000
